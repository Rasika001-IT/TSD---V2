PORT=3000

NODE_ENV=development



# Redis Configuration

REDIS_HOST=redis

REDIS_PORT=6379

REDIS_PASSWORD=


# WordPress Configuration

WORDPRESS_API_URL=https://thesuccessdigest.com/wp-json/wp/v2

# Cache Configuration

CACHE_TTL_POSTS=3600 

CACHE_TTL_CATEGORIES=86400 

CACHE_TTL_TAGS=86400 

CACHE_TTL_SINGLE_POST=1800 



# Refresh Configuration

REFRESH_INTERVAL_POSTS=300 

REFRESH_INTERVAL_CATEGORIES=3600 

REFRESH_INTERVAL_TAGS=3600 


FRONTEND_URL=http://localhost